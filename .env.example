# ============================================
# Social Growth AI — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# --- GEMINI (REQUIRED — primary AI for all agents) ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# --- GROQ (REQUIRED — LLaMA 3.3 for Caption Agent) ---
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# --- YOUTUBE DATA API (OPTIONAL — enhances Spy & Recreate for YouTube URLs) ---
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=AIza...

# --- SUPABASE (OPTIONAL — for auth & cloud saves) ---
# Get from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# --- UPSTASH REDIS (OPTIONAL — for rate limiting) ---
# Get from: https://upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...
